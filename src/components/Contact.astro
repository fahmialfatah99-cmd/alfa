---
const formspreeId = 'your-form-id'; // Ganti dengan ID Formspree kamu
---

<section id="kontak" class="py-24 md:py-32 relative overflow-hidden">
  <!-- Gradient background -->
  <div class="absolute inset-0 bg-gradient-to-b from-cream-50 via-sage-500/5 to-cream-50 dark:from-cream-900 dark:via-sage-500/5 dark:to-cream-900"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-sage-400/5 rounded-full blur-3xl pointer-events-none"></div>

  <div class="section-container relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-start">
      <!-- Left: Contact info -->
      <div class="reveal">
        <span class="inline-block text-sm font-semibold text-sage-600 dark:text-sage-400 uppercase tracking-widest mb-4">
          Kontak
        </span>
        <h2 class="fluid-h2 text-cream-900 dark:text-cream-50 mb-6">
          Mulai Percakapan
        </h2>
        <p class="text-cream-600 dark:text-cream-300 text-lg leading-relaxed mb-10">
          Punya ide projek atau sekadar ingin diskusi? Kirim pesan dan saya akan balas dalam 24 jam.
        </p>

        <!-- Contact items -->
        <div class="space-y-6">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-xl bg-sage-500/10 flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#7A9368" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            </div>
            <div>
              <p class="text-sm font-medium text-cream-500 dark:text-cream-400 mb-0.5">Email</p>
              <a href="mailto:fahmialfatah@outlook.co.id" class="text-cream-900 dark:text-cream-50 font-medium hover:text-sage-600 dark:hover:text-sage-400 transition-colors">
                fahmialfatah@outlook.co.id
              </a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-xl bg-sage-500/10 flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#7A9368" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </div>
            <div>
              <p class="text-sm font-medium text-cream-500 dark:text-cream-400 mb-0.5">WhatsApp</p>
              <a href="https://wa.me/6289673678180" class="text-cream-900 dark:text-cream-50 font-medium hover:text-sage-600 dark:hover:text-sage-400 transition-colors">
                +62 896 7367 8180
              </a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-xl bg-sage-500/10 flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#7A9368" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <p class="text-sm font-medium text-cream-500 dark:text-cream-400 mb-0.5">Lokasi</p>
              <p class="text-cream-900 dark:text-cream-50 font-medium">
                Bekasi, Indonesia
              </p>
            </div>
          </div>
        </div>

        <!-- Social links -->
        <div class="mt-10">
          <p class="text-sm font-medium text-cream-500 dark:text-cream-400 mb-4">Ikuti saya</p>
          <div class="flex gap-3">
            <a href="#" aria-label="Instagram" class="w-11 h-11 rounded-full glass-card flex items-center justify-center hover:border-sage-400 hover:scale-110 transition-all">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-cream-600 dark:text-cream-300"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
            </a>
            <a href="#" aria-label="GitHub" class="w-11 h-11 rounded-full glass-card flex items-center justify-center hover:border-sage-400 hover:scale-110 transition-all">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-cream-600 dark:text-cream-300"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
            </a>
            <a href="#" aria-label="LinkedIn" class="w-11 h-11 rounded-full glass-card flex items-center justify-center hover:border-sage-400 hover:scale-110 transition-all">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-cream-600 dark:text-cream-300"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
            </a>
            <a href="#" aria-label="Dribbble" class="w-11 h-11 rounded-full glass-card flex items-center justify-center hover:border-sage-400 hover:scale-110 transition-all">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-cream-600 dark:text-cream-300"><circle cx="12" cy="12" r="10"/><path d="M19.13 5.09C15.22 9.14 10 10.44 2.25 10.94"/><path d="M21.75 12.84c-6.62-1.41-12.14 1-16.38 6.32"/><path d="M8.56 2.75c4.37 6 6 9.42 8 17.72"/></svg>
            </a>
          </div>
        </div>
      </div>

      <!-- Right: Form -->
      <div class="reveal">
        <form
          action={`https://formspree.io/f/${formspreeId}`}
          method="POST"
          class="glass-card rounded-3xl p-8 md:p-10"
          id="contact-form"
        >
          <div class="space-y-5">
            <!-- Name -->
            <div>
              <label for="name" class="block text-sm font-medium text-cream-700 dark:text-cream-200 mb-2">
                Nama Lengkap
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                placeholder="Masukkan nama kamu"
                class="form-input"
              />
            </div>

            <!-- Email -->
            <div>
              <label for="email" class="block text-sm font-medium text-cream-700 dark:text-cream-200 mb-2">
                Alamat Email
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                placeholder="email@contoh.com"
                class="form-input"
              />
            </div>

            <!-- Subject -->
            <div>
              <label for="subject" class="block text-sm font-medium text-cream-700 dark:text-cream-200 mb-2">
                Subjek
              </label>
              <input
                type="text"
                id="subject"
                name="subject"
                placeholder="Tentang apa projeknya?"
                class="form-input"
              />
            </div>

            <!-- Message -->
            <div>
              <label for="message" class="block text-sm font-medium text-cream-700 dark:text-cream-200 mb-2">
                Pesan
              </label>
              <textarea
                id="message"
                name="message"
                rows="5"
                required
                placeholder="Ceritakan tentang projek kamu..."
                class="form-input resize-none"
              ></textarea>
            </div>

            <!-- Honeypot spam protection -->
            <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" class="hidden" />

            <!-- Submit button -->
            <button
              type="submit"
              class="btn-primary w-full group"
              id="submit-btn"
            >
              <span>Kirim Pesan</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-1 group-hover:-translate-y-0.5"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>
            </button>

            <!-- Success message (hidden by default) -->
            <div id="form-success" class="hidden text-center py-4">
              <div class="w-12 h-12 mx-auto mb-3 rounded-full bg-sage-500/10 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#7A9368" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              </div>
              <p class="font-medium text-cream-900 dark:text-cream-50">Pesan terkirim!</p>
              <p class="text-sm text-cream-500 dark:text-cream-400 mt-1">Saya akan balas secepatnya.</p>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  // Scroll reveal
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('#kontak .reveal').forEach((el) => {
    observer.observe(el);
  });

  // Form submission handling (AJAX for Formspree)
  const form = document.getElementById('contact-form');
  const submitBtn = document.getElementById('submit-btn');
  const successMsg = document.getElementById('form-success');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const formData = new FormData(form);
    submitBtn.disabled = true;
    submitBtn.innerHTML = '<span>Mengirim...</span>';

    try {
      const response = await fetch(form.action, {
        method: 'POST',
        body: formData,
        headers: {
          Accept: 'application/json',
        },
      });

      if (response.ok) {
        form.querySelector('.space-y-5').classList.add('hidden');
        successMsg.classList.remove('hidden');
      } else {
        throw new Error('Submit failed');
      }
    } catch (error) {
      submitBtn.disabled = false;
      submitBtn.innerHTML = '<span>Kirim Pesan</span>';
      alert('Terjadi kesalahan. Silakan coba lagi atau kirim email langsung.');
    }
  });
</script>
