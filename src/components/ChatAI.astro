---
// AI Chat Widget — Powered by Google Gemini
---

<div id="alfa-ai-chat">
  <button id="alfa-ai-toggle" class="chat-toggle" aria-label="Buka AI Chat">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
    </svg>
  </button>

  <div id="alfa-ai-panel" class="chat-panel hidden">
    <div class="chat-header">
      <div class="chat-header-info">
        <div class="chat-avatar">AI</div>
        <div>
          <p class="chat-name">Alfa AI</p>
          <p class="chat-status">Online · Siap bantu</p>
        </div>
      </div>
      <button id="alfa-ai-close" class="chat-close">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>

    <div id="alfa-ai-messages" class="chat-messages">
      <div class="msg msg-bot">
        <div class="msg-bubble">
          Halo! 👋 Saya Alfa AI, asisten virtual dari alfa. Ada yang bisa saya bantu?
          <div class="msg-suggestions">
            <button class="suggestion" data-query="Jelaskan layanan yang ditawarkan">Layanan</button>
            <button class="suggestion" data-query="Berapa harga pembuatan website?">Harga</button>
            <button class="suggestion" data-query="Contoh project portfolio">Portfolio</button>
          </div>
        </div>
      </div>
    </div>

    <div class="chat-input-area">
      <input type="text" id="alfa-ai-input" placeholder="Tulis pesan..." autocomplete="off" />
      <button id="alfa-ai-send" class="chat-send" aria-label="Kirim">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
        </svg>
      </button>
    </div>
  </div>
</div>

<style is:global>
  .chat-toggle {
    position: fixed; bottom: 24px; right: 24px; z-index: 9999;
    width: 56px; height: 56px; border-radius: 50%; border: none;
    background: linear-gradient(135deg, #8B7355, #C9A96E);
    color: #fff; cursor: pointer; display: flex; align-items: center;
    justify-content: center; box-shadow: 0 4px 20px rgba(201,169,110,0.3);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .chat-toggle:hover { transform: scale(1.05); box-shadow: 0 6px 25px rgba(201,169,110,0.4); }
  .chat-panel {
    position: fixed; bottom: 92px; right: 24px; z-index: 9999;
    width: 360px; height: 520px; border-radius: 16px; overflow: hidden;
    background: rgba(28,27,24,0.95); backdrop-filter: blur(20px);
    border: 1px solid rgba(201,169,110,0.15);
    box-shadow: 0 20px 60px rgba(0,0,0,0.5);
    display: flex; flex-direction: column;
    animation: slideUp 0.3s ease;
  }
  .chat-panel.hidden { display: none; }
  @keyframes slideUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
  .chat-header {
    padding: 16px 18px; display: flex; justify-content: space-between;
    align-items: center; border-bottom: 1px solid rgba(255,255,255,0.06);
    background: rgba(201,169,110,0.06);
  }
  .chat-header-info { display: flex; align-items: center; gap: 12px; }
  .chat-avatar {
    width: 38px; height: 38px; border-radius: 50%; display: flex;
    align-items: center; justify-content: center;
    background: linear-gradient(135deg, #8B7355, #C9A96E);
    color: #fff; font-weight: 700; font-size: 0.8rem;
  }
  .chat-name { color: #f0f0f0; font-size: 0.85rem; font-weight: 600; }
  .chat-status { color: #6b7280; font-size: 0.65rem; }
  .chat-close { background: none; border: none; color: #6b7280; cursor: pointer; padding: 4px; border-radius: 6px; }
  .chat-close:hover { background: rgba(255,255,255,0.05); color: #f0f0f0; }
  .chat-messages {
    flex: 1; overflow-y: auto; padding: 16px; display: flex;
    flex-direction: column; gap: 12px;
  }
  .chat-messages::-webkit-scrollbar { width: 4px; }
  .chat-messages::-webkit-scrollbar-thumb { background: rgba(201,169,110,0.3); border-radius: 2px; }
  .msg { display: flex; }
  .msg-bot { justify-content: flex-start; }
  .msg-user { justify-content: flex-end; }
  .msg-bubble {
    max-width: 85%; padding: 10px 14px; border-radius: 12px;
    font-size: 0.8rem; line-height: 1.6;
  }
  .msg-bot .msg-bubble { background: rgba(255,255,255,0.04); color: #d4d4d4; border: 1px solid rgba(255,255,255,0.04); }
  .msg-user .msg-bubble { background: rgba(201,169,110,0.12); color: #f0e6d0; border: 1px solid rgba(201,169,110,0.1); }
  .typing-indicator { display: flex; gap: 4px; padding: 4px 0; }
  .typing-indicator span { width: 6px; height: 6px; border-radius: 50%; background: #6b7280; animation: typing 1.4s ease infinite; }
  .typing-indicator span:nth-child(2) { animation-delay: 0.2s; }
  .typing-indicator span:nth-child(3) { animation-delay: 0.4s; }
  @keyframes typing { 0%,60%,100% { opacity: 0.3; } 30% { opacity: 1; } }
  .msg-suggestions { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 8px; }
  .suggestion {
    padding: 4px 12px; border-radius: 50px; border: 1px solid rgba(201,169,110,0.15);
    background: rgba(201,169,110,0.04); color: #C9A96E; cursor: pointer;
    font-size: 0.7rem; transition: all 0.2s;
  }
  .suggestion:hover { background: rgba(201,169,110,0.1); border-color: rgba(201,169,110,0.3); }
  .chat-input-area {
    padding: 12px 14px; display: flex; gap: 8px; align-items: center;
    border-top: 1px solid rgba(255,255,255,0.04);
  }
  .chat-input-area input {
    flex: 1; padding: 10px 14px; border-radius: 10px; border: 1px solid rgba(255,255,255,0.06);
    background: rgba(255,255,255,0.03); color: #f0f0f0; font-size: 0.8rem; font-family: inherit;
    outline: none; transition: border-color 0.3s;
  }
  .chat-input-area input:focus { border-color: rgba(201,169,110,0.3); }
  .chat-input-area input::placeholder { color: #6b7280; }
  .chat-send {
    width: 38px; height: 38px; border-radius: 10px; border: none;
    background: linear-gradient(135deg, #8B7355, #C9A96E); color: #fff;
    cursor: pointer; display: flex; align-items: center; justify-content: center;
    transition: transform 0.2s; flex-shrink: 0;
  }
  .chat-send:hover { transform: scale(1.05); }
  .chat-send:disabled { opacity: 0.5; cursor: not-allowed; }
  @media (max-width: 480px) {
    .chat-panel { width: calc(100vw - 32px); right: 16px; bottom: 84px; height: 60vh; }
  }
</style>

<script>
(function() {
  const API_KEY = 'GEMINI_API_KEY_HERE'; // Ganti dengan API key dari Google AI Studio
  const API_URL = 'https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent';

  const toggle = document.getElementById('alfa-ai-toggle');
  const panel = document.getElementById('alfa-ai-panel');
  const close = document.getElementById('alfa-ai-close');
  const input = document.getElementById('alfa-ai-input');
  const send = document.getElementById('alfa-ai-send');
  const msgs = document.getElementById('alfa-ai-messages');

  const SYSTEM_PROMPT = `Kamu adalah asisten virtual dari "alfa" — jasa pembuatan website premium oleh Fahmi Alfatah.
  Jawab pertanyaan dengan ramah, dalam Bahasa Indonesia, dan promosikan layanan alfa dengan natural.
  Layanan: Website Development (Astro, React, Next.js), UI/UX Design, Performance Optimization, Maintenance & Support.
  Portfolio: FlowBoard (React/Node.js), InsightDash (Vue.js/D3.js), VaultSecure (Next.js).
  Harga: Mulai dari Rp500rb untuk landing page sederhana, custom project mulai Rp2jt.
  Kontak: WA 089620310945 atau email hello@alfaproject.id.`;

  toggle.addEventListener('click', () => { panel.classList.toggle('hidden'); if (!panel.classList.contains('hidden')) input.focus(); });
  close.addEventListener('click', () => panel.classList.add('hidden'));

  async function sendMessage(text) {
    if (!text.trim()) return;
    appendMessage('user', text); input.value = ''; send.disabled = true;
    showTyping();
    try {
      const res = await fetch(API_URL + '?key=' + API_KEY, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          contents: [{ parts: [{ text: SYSTEM_PROMPT + '\n\nPertanyaan user: ' + text + '\n\nJawab dengan ramah dan singkat (maks 3 paragraf).' }] }],
          generationConfig: { temperature: 0.7, maxOutputTokens: 300 }
        })
      });
      const data = await res.json();
      removeTyping();
      const reply = data?.candidates?.[0]?.content?.parts?.[0]?.text || 'Maaf, saya tidak bisa menjawab saat ini. Silakan hubungi langsung WA 089620310945 😊';
      appendMessage('bot', reply);
    } catch (err) { removeTyping(); appendMessage('bot', 'Maaf, terjadi gangguan. Silakan hubungi langsung WA 089620310945 🙏'); }
    send.disabled = false;
  }

  function appendMessage(role, text) {
    const div = document.createElement('div');
    div.className = 'msg msg-' + role;
    div.innerHTML = '<div class="msg-bubble">' + text.replace(/\n/g, '<br>') + '</div>';
    msgs.appendChild(div); msgs.scrollTop = msgs.scrollHeight;
  }
  function showTyping() {
    const div = document.createElement('div'); div.className = 'msg msg-bot'; div.id = 'typing-msg';
    div.innerHTML = '<div class="msg-bubble"><div class="typing-indicator"><span></span><span></span><span></span></div></div>';
    msgs.appendChild(div); msgs.scrollTop = msgs.scrollHeight;
  }
  function removeTyping() { const el = document.getElementById('typing-msg'); if (el) el.remove(); }

  send.addEventListener('click', () => sendMessage(input.value));
  input.addEventListener('keydown', (e) => { if (e.key === 'Enter') sendMessage(input.value); });
  document.querySelectorAll('.suggestion').forEach(btn => {
    btn.addEventListener('click', () => sendMessage(btn.getAttribute('data-query')));
  });
})();
</script>
