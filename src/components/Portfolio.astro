    icon: 'palette',
  },
  {
    title: 'Full Responsive',
    description: 'Tampil sempurna di semua perangkat — desktop, tablet, hingga smartphone.',
    icon: 'smartphone',
  },
  {
    title: 'Super Fast Loading',
    description: 'Dioptimalkan untuk kecepatan dengan skor PageSpeed 90+ untuk pengalaman terbaik.',
    icon: 'zap',
  },
  {
    title: 'SEO Friendly',
    description: 'Struktur semantic dan meta tags teroptimasi untuk peringkat terbaik di Google.',
    icon: 'search',
  },
  {
    title: 'Integrasi WhatsApp',
    description: 'Tombol chat langsung ke WhatsApp untuk memudahkan calon pelanggan menghubungi.',
    icon: 'message-circle',
  },
  {
    title: 'Maintenance Support',
    description: 'Dukungan pasca-launch untuk update konten, perbaikan, dan penambahan fitur.',
    icon: 'settings',
  },
