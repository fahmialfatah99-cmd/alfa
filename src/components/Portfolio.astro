const iconPaths = {
  palette: '<path d="M12 2a10 10 0 1 0 10 10c0-1.1-.9-2-2-2h-2.5a1.5 1.5 0 0 1-1.5-1.5v-.5a2 2 0 0 0-2-2h-1a2 2 0 0 1-2-2V7a2 2 0 0 0-2-2h-1a2 2 0 0 1-2-2 10 10 0 0 1 2-8z"/><circle cx="7.5" cy="10.5" r="1.25"/><circle cx="12" cy="7.5" r="1.25"/><circle cx="16.5" cy="10.5" r="1.25"/><circle cx="14.5" cy="15.5" r="1.25"/><circle cx="9.5" cy="15.5" r="1.25"/>',
  smartphone: '<rect width="14" height="20" x="5" y="2" rx="2" ry="2"/><path d="M12 18h.01"/>',
  zap: '<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>',
  search: '<circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>',
  'message-circle': '<path d="M7.9 20A9 9 0 1 0 4 16.1L2 22z"/>',
  settings: '<path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/>',
};
---

<section id="portofolio" class="py-24 md:py-32 relative overflow-hidden">
  <!-- Parallax background layers -->
  <div class="absolute inset-0 bg-grid opacity-30"></div>
  <div class="absolute top-10 -right-32 w-[500px] h-[500px] bg-sage-400/15 rounded-full blur-3xl pointer-events-none feature-parallax" data-speed="0.03"></div>
  <div class="absolute bottom-20 -left-40 w-[600px] h-[600px] bg-accent-400/10 rounded-full blur-3xl pointer-events-none feature-parallax" data-speed="0.02"></div>
  <div class="absolute top-1/2 left-1/3 w-72 h-72 bg-sage-300/10 rounded-full blur-2xl pointer-events-none feature-parallax" data-speed="0.05"></div>

  <!-- Floating geometric shapes -->
  <div class="absolute top-32 right-20 w-20 h-20 border border-sage-400/20 rounded-2xl rotate-12 pointer-events-none feature-parallax" data-speed="0.08"></div>
  <div class="absolute bottom-40 left-16 w-16 h-16 border border-accent-400/20 rounded-full pointer-events-none feature-parallax" data-speed="0.06"></div>

  <div class="section-container relative z-10">
    <!-- Section header -->
    <div class="text-center max-w-2xl mx-auto mb-16 reveal">
      <span class="inline-block text-sm font-semibold text-sage-600 dark:text-sage-400 uppercase tracking-widest mb-4">
        Fitur & Spesifikasi
      </span>
      <h2 class="fluid-h2 text-cream-900 dark:text-cream-50 mb-6">
        Website yang Dapat Kami Buat
      </h2>
      <p class="text-cream-600 dark:text-cream-300 text-lg leading-relaxed">
        Setiap website dibangun dengan standar premium — cepat, responsif, dan dirancang untuk mengkonversi pengunjung menjadi pelanggan.
      </p>
    </div>

    <!-- Features grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 reveal-stagger">
      {features.map((feature) => (
        <div class="glass-card rounded-2xl p-8 group hover:-translate-y-2 transition-all duration-500">
          <!-- Icon -->
          <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-sage-500/15 to-accent-500/15 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-500">
            <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#7A9368" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={iconPaths[feature.icon]}></svg>
          </div>

          <h3 class="text-xl font-display font-bold text-cream-900 dark:text-cream-50 mb-3 group-hover:text-sage-600 dark:group-hover:text-sage-400 transition-colors">
            {feature.title}
          </h3>
          <p class="text-cream-600 dark:text-cream-300 leading-relaxed">
            {feature.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  // Scroll reveal
  const observerOptions = {
    threshold: 0.1,
    rootMargin: '0px 0px -50px 0px',
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
        observer.unobserve(entry.target);
      }
    });
  }, observerOptions);

  document.querySelectorAll('#portofolio .reveal, #portofolio .reveal-stagger').forEach((el) => {
    observer.observe(el);
  });

  // Parallax background effect
  const parallaxEls = document.querySelectorAll('.feature-parallax');

  window.addEventListener('scroll', () => {
    const scrolled = window.pageYOffset;
    const section = document.getElementById('portofolio');
    if (!section) return;

    const sectionTop = section.offsetTop;
    const sectionHeight = section.offsetHeight;

    if (scrolled + window.innerHeight > sectionTop && scrolled < sectionTop + sectionHeight) {
      const relativeScroll = scrolled - sectionTop;
      parallaxEls.forEach((el) => {
        const speed = parseFloat(el.dataset.speed) || 0.03;
        el.style.transform = `translateY(${relativeScroll * speed}px)`;
      });
    }
  }, { passive: true });
</script>
