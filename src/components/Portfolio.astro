---
const projects = [
  {
    title: 'Lumina Studio',
    category: 'Brand Website',
    description: 'Website agensi desain dengan animasi smooth dan portfolio interaktif.',
    tags: ['Astro', 'Tailwind', 'GSAP'],
    color: 'from-sage-400 to-sage-600',
  },
  {
    title: 'Nexa Commerce',
    category: 'E-commerce',
    description: 'Toko online modern dengan sistem checkout yang dioptimalkan untuk konversi.',
    tags: ['Next.js', 'Stripe', 'Tailwind'],
    color: 'from-accent-400 to-accent-600',
  },
  {
    title: 'Verse Blog',
    category: 'Content Platform',
    description: 'Platform blog dengan sistem pencarian canggih dan dark mode yang elegan.',
    tags: ['Astro', 'MDX', 'Search'],
    color: 'from-cream-400 to-cream-600',
  },
  {
    title: 'Pulse Dashboard',
    category: 'SaaS Dashboard',
    description: 'Dashboard analitik dengan real-time charts dan manajemen data.',
    tags: ['React', 'D3.js', 'TypeScript'],
    color: 'from-sage-500 to-accent-500',
  },
  {
    title: 'Haven Retreat',
    category: 'Hospitality',
    description: 'Website villa premium dengan sistem booking dan galeri foto imersif.',
    tags: ['Astro', 'Formspree', 'Gallery'],
    color: 'from-accent-500 to-sage-400',
  },
  {
    title: 'Cove Finance',
    category: 'Fintech Landing',
    description: 'Landing page produk fintech dengan fokus pada trust dan konversi.',
    tags: ['Next.js', 'Framer Motion'],
    color: 'from-sage-600 to-accent-400',
  },
];
---

<section id="portofolio" class="py-24 md:py-32 relative overflow-hidden bg-cream-100/50 dark:bg-cream-800/20">
  <!-- Parallax background -->
  <div class="absolute inset-0 bg-grid opacity-40"></div>
  <div class="absolute top-20 right-0 w-96 h-96 bg-accent-400/10 rounded-full blur-3xl pointer-events-none portfolio-parallax" data-speed="0.02"></div>
  <div class="absolute bottom-40 -left-20 w-80 h-80 bg-sage-400/10 rounded-full blur-3xl pointer-events-none portfolio-parallax" data-speed="0.03"></div>

  <div class="section-container relative z-10">
    <!-- Section header -->
    <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-16 gap-6 reveal">
      <div class="max-w-xl">
        <span class="inline-block text-sm font-semibold text-sage-600 dark:text-sage-400 uppercase tracking-widest mb-4">
          Portofolio
        </span>
        <h2 class="fluid-h2 text-cream-900 dark:text-cream-50 mb-4">
          Karya Terpilih
        </h2>
        <p class="text-cream-600 dark:text-cream-300 text-lg leading-relaxed">
          Beberapa proyek terbaru yang telah kami kerjakan untuk klien dari berbagai industri.
        </p>
      </div>
      <a href="#kontak" class="btn-secondary self-start md:self-end">
        Lihat Semua
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>

    <!-- Portfolio grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 reveal-stagger">
      {projects.map((project) => (
        <div class="portfolio-card group">
          <div class="portfolio-card-inner glass-card rounded-2xl overflow-hidden">
            <!-- Project preview / mockup -->
            <div class={`relative h-56 bg-gradient-to-br ${project.color} overflow-hidden`}>
              <!-- Device mockup placeholder -->
              <div class="absolute inset-4 bg-cream-900/20 backdrop-blur-sm rounded-xl flex items-center justify-center">
                <div class="text-center text-white/80">
                  <div class="w-16 h-16 mx-auto mb-3 rounded-full bg-white/10 flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="14" x="3" y="4" rx="2"/><path d="M3 10h18"/></svg>
                  </div>
                  <p class="text-xs font-medium opacity-70">Preview Mockup</p>
                </div>
              </div>

              <!-- Hover overlay -->
              <div class="absolute inset-0 bg-cream-900/60 backdrop-blur-sm opacity-0 group-hover:opacity-100 transition-all duration-500 flex items-center justify-center">
                <span class="px-5 py-2.5 rounded-full bg-white text-cream-900 text-sm font-medium transform translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
                  Lihat Projek
                </span>
              </div>
            </div>

            <!-- Project info -->
            <div class="p-6">
              <div class="flex items-center justify-between mb-2">
                <span class="text-xs font-medium text-sage-600 dark:text-sage-400 uppercase tracking-wider">
                  {project.category}
                </span>
              </div>
              <h3 class="text-lg font-display font-bold text-cream-900 dark:text-cream-50 mb-2 group-hover:text-sage-600 dark:group-hover:text-sage-400 transition-colors">
                {project.title}
              </h3>
              <p class="text-sm text-cream-600 dark:text-cream-300 mb-4 leading-relaxed">
                {project.description}
              </p>
              <div class="flex flex-wrap gap-2">
                {project.tags.map((tag) => (
                  <span class="px-2.5 py-1 text-xs rounded-full bg-cream-200/60 dark:bg-cream-700/40 text-cream-600 dark:text-cream-300">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  // Scroll reveal
  const observerOptions = {
    threshold: 0.1,
    rootMargin: '0px 0px -50px 0px',
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
        observer.unobserve(entry.target);
      }
    });
  }, observerOptions);

  document.querySelectorAll('#portofolio .reveal, #portofolio .reveal-stagger').forEach((el) => {
    observer.observe(el);
  });

  // 3D Tilt effect on portfolio cards
  const cards = document.querySelectorAll('.portfolio-card');

  cards.forEach((card) => {
    const inner = card.querySelector('.portfolio-card-inner');

    card.addEventListener('mousemove', (e) => {
      const rect = card.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      const centerX = rect.width / 2;
      const centerY = rect.height / 2;
      const rotateX = (y - centerY) / 20;
      const rotateY = (centerX - x) / 20;

      inner.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale3d(1.02, 1.02, 1.02)`;
    });

    card.addEventListener('mouseleave', () => {
      inner.style.transform = 'perspective(1000px) rotateX(0) rotateY(0) scale3d(1, 1, 1)';
    });
  });

  // Parallax background
  const parallaxEls = document.querySelectorAll('.portfolio-parallax');

  window.addEventListener('scroll', () => {
    const scrolled = window.pageYOffset;
    const section = document.getElementById('portofolio');
    const sectionTop = section.offsetTop;
    const sectionHeight = section.offsetHeight;

    if (scrolled + window.innerHeight > sectionTop && scrolled < sectionTop + sectionHeight) {
      const relativeScroll = scrolled - sectionTop;
      parallaxEls.forEach((el) => {
        const speed = parseFloat(el.dataset.speed) || 0.02;
        el.style.transform = `translateY(${relativeScroll * speed}px)`;
      });
    }
  }, { passive: true });
</script>
