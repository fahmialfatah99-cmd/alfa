---
---

<section id="hero" class="relative min-h-screen flex items-center overflow-hidden pt-20">
  <!-- Parallax background shapes -->
  <div class="absolute inset-0 bg-grid opacity-60"></div>

  <!-- Parallax shapes - multi layer -->
  <div class="parallax-shape bg-sage-400/20 w-[500px] h-[500px] -top-40 -right-40 parallax-layer" data-speed="0.05"></div>
  <div class="parallax-shape bg-accent-400/15 w-[400px] h-[400px] top-1/3 -left-32 parallax-layer" data-speed="0.08"></div>
  <div class="parallax-shape bg-sage-500/10 w-[300px] h-[300px] bottom-20 right-1/4 parallax-layer" data-speed="0.03"></div>

  <!-- Floating geometric elements -->
  <div class="absolute top-32 right-[15%] w-20 h-20 border border-cream-300/40 dark:border-cream-700/40 rounded-2xl rotate-12 animate-float-slow parallax-layer" data-speed="0.04"></div>
  <div class="absolute bottom-40 left-[10%] w-16 h-16 bg-sage-400/10 rounded-full animate-float parallax-layer" data-speed="0.06"></div>
  <div class="absolute top-1/2 right-[8%] w-3 h-3 bg-accent-400/40 rounded-full animate-float-slow parallax-layer" data-speed="0.07"></div>

  <div class="section-container relative z-10">
    <div class="max-w-4xl">
      <!-- Eyebrow -->
      <div class="hero-stagger inline-flex items-center gap-2 px-4 py-2 rounded-full glass-card mb-8">
        <span class="w-2 h-2 rounded-full bg-sage-500 animate-pulse"></span>
        <span class="text-xs font-medium text-cream-600 dark:text-cream-300 tracking-wide uppercase">
          Tersedia untuk projek baru
        </span>
      </div>

      <!-- Headline -->
      <h1 class="fluid-h1 font-display font-bold text-cream-900 dark:text-cream-50 text-balance mb-6">
        <span class="hero-stagger block">Kami Ubah Ide</span>
        <span class="hero-stagger block">Menjadi Website</span>
        <span class="hero-stagger block gradient-text">Elegan & Berkelas.</span>
      </h1>

      <!-- Subheadline -->
      <p class="hero-stagger fluid-lead text-cream-600 dark:text-cream-300 max-w-2xl mb-10 leading-relaxed">
        alfa menghadirkan layanan pembuatan website profesional dengan desain premium, performa tinggi, dan pengalaman pengguna yang luar biasa. Dibuat dengan teliti untuk brandmu.
      </p>

      <!-- CTA Buttons -->
      <div class="hero-stagger flex flex-wrap items-center gap-4">
        <a href="#kontak" class="btn-primary group">
          Mulai Projek
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-1"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a href="#portofolio" class="btn-secondary group">
          Lihat Portofolio
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-y-0.5"><path d="M12 5v14"/><path d="m19 12-7 7-7-7"/></svg>
        </a>
      </div>

      <!-- Trust badges -->
      <div class="hero-stagger mt-16 flex items-center gap-8">
        <div class="flex -space-x-3">
          <div class="w-10 h-10 rounded-full bg-gradient-to-br from-sage-400 to-sage-600 border-2 border-cream-50 dark:border-cream-900 flex items-center justify-center text-white text-xs font-bold">A</div>
          <div class="w-10 h-10 rounded-full bg-gradient-to-br from-accent-400 to-accent-600 border-2 border-cream-50 dark:border-cream-900 flex items-center justify-center text-white text-xs font-bold">B</div>
          <div class="w-10 h-10 rounded-full bg-gradient-to-br from-cream-400 to-cream-600 border-2 border-cream-50 dark:border-cream-900 flex items-center justify-center text-white text-xs font-bold">C</div>
          <div class="w-10 h-10 rounded-full bg-cream-200 dark:bg-cream-700 border-2 border-cream-50 dark:border-cream-900 flex items-center justify-center text-cream-600 dark:text-cream-300 text-xs font-medium">+12</div>
        </div>
        <div>
          <div class="flex items-center gap-1 mb-0.5">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="#9CAF88" stroke="#9CAF88" stroke-width="1"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="#9CAF88" stroke="#9CAF88" stroke-width="1"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="#9CAF88" stroke="#9CAF88" stroke-width="1"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="#9CAF88" stroke="#9CAF88" stroke-width="1"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="#9CAF88" stroke="#9CAF88" stroke-width="1"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          </div>
          <p class="text-xs text-cream-500 dark:text-cream-400">
            <span class="font-semibold text-cream-700 dark:text-cream-200">50+ klien</span> puas dengan hasilnya
          </p>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 animate-bounce">
    <span class="text-xs text-cream-400 uppercase tracking-widest">Scroll</span>
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-cream-400"><path d="M12 5v14"/><path d="m19 12-7 7-7-7"/></svg>
  </div>
</section>

<script>
  import { gsap } from 'gsap';

  // Hero stagger animation on load
  window.addEventListener('load', () => {
    gsap.from('.hero-stagger', {
      y: 40,
      opacity: 0,
      duration: 1,
      stagger: 0.12,
      ease: 'power3.out',
      delay: 0.2,
    });
  });

  // Parallax effect on scroll
  const parallaxLayers = document.querySelectorAll('.parallax-layer');

  window.addEventListener('scroll', () => {
    const scrolled = window.pageYOffset;

    parallaxLayers.forEach((layer) => {
      const speed = parseFloat(layer.dataset.speed) || 0.05;
      const yPos = scrolled * speed;
      layer.style.transform = `translateY(${yPos}px)`;
    });
  }, { passive: true });
</script>
