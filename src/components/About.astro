---
const skills = [
  { name: 'Astro', level: 95 },
  { name: 'React / Next.js', level: 90 },
  { name: 'Tailwind CSS', level: 95 },
  { name: 'TypeScript', level: 85 },
  { name: 'Node.js', level: 80 },
  { name: 'UI/UX Design', level: 88 },
];

const techStack = ['Astro', 'React', 'Next.js', 'Tailwind', 'GSAP', 'TypeScript', 'Node.js', 'Figma'];
---

<section id="tentang" class="py-24 md:py-32 relative overflow-hidden">
  <div class="section-container relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">
      <!-- Left: Photo + decorative elements -->
      <div class="relative reveal">
        <!-- Decorative frame -->
        <div class="absolute -top-4 -left-4 w-full h-full border-2 border-sage-400/30 rounded-3xl -z-10"></div>
        <div class="absolute -bottom-4 -right-4 w-full h-full bg-gradient-to-br from-sage-500/10 to-accent-500/10 rounded-3xl -z-10"></div>

        <!-- Photo -->
        <div class="relative aspect-[4/5] rounded-2xl overflow-hidden bg-gradient-to-br from-cream-200 to-cream-300 dark:from-cream-700 dark:to-cream-800">
          <img
            src={`${Astro.base}/profile.jpg`}
            alt="Foto Fahmi Alfatah"
            class="w-full h-full object-cover"
            loading="lazy"
          />

          <!-- Floating badge -->
          <div class="absolute bottom-6 left-6 right-6 glass-card rounded-xl p-4 animate-float-slow">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-sage-500/10 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#7A9368" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="m9 12 2 2 4-4"/></svg>
              </div>
              <div>
                <p class="text-sm font-semibold text-cream-900 dark:text-cream-50">5+ Tahun Pengalaman</p>
                <p class="text-xs text-cream-500 dark:text-cream-400">Web Development & Design</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: Content -->
      <div class="reveal">
        <span class="inline-block text-sm font-semibold text-sage-600 dark:text-sage-400 uppercase tracking-widest mb-4">
          Tentang Saya
        </span>
        <h2 class="fluid-h2 text-cream-900 dark:text-cream-50 mb-6">
          Halo, saya Fahmi Alfatah
        </h2>

        <!-- Quote -->
        <blockquote class="text-xl leading-relaxed text-cream-700 dark:text-cream-200 font-light mb-8 pl-6 border-l-2 border-sage-500 italic">
          "Saya percaya website yang hebat bukan hanya tentang tampilan yang indah, tapi juga tentang pengalaman yang berkesan dan performa yang dapat diandalkan."
        </blockquote>

        <p class="text-cream-600 dark:text-cream-300 leading-relaxed mb-8">
          Sebagai pengembang web independen, saya fokus menciptakan website yang tidak hanya terlihat premium, tetapi juga cepat, mudah digunakan, dan benar-benar membantu bisnis tumbuh. Setiap proyek saya kerjakan dengan perhatian pada detail terkecil.
        </p>

        <!-- Skill bars -->
        <div class="space-y-4 mb-8">
          {skills.slice(0, 4).map((skill) => (
            <div>
              <div class="flex justify-between mb-1.5">
                <span class="text-sm font-medium text-cream-700 dark:text-cream-200">{skill.name}</span>
                <span class="text-xs text-cream-500 dark:text-cream-400">{skill.level}%</span>
              </div>
              <div class="h-1.5 rounded-full bg-cream-200 dark:bg-cream-700 overflow-hidden">
                <div
                  class="h-full rounded-full bg-gradient-to-r from-sage-500 to-sage-600 skill-bar"
                  style={`width: 0%; --target-width: ${skill.level}%`}
                ></div>
              </div>
            </div>
          ))}
        </div>

        <!-- Tech stack pills -->
        <div>
          <p class="text-sm font-medium text-cream-700 dark:text-cream-200 mb-3">Tech Stack Favorit</p>
          <div class="flex flex-wrap gap-2">
            {techStack.map((tech) => (
              <span class="px-3 py-1.5 text-xs font-medium rounded-full bg-cream-100 dark:bg-cream-800 text-cream-600 dark:text-cream-300 border border-cream-200 dark:border-cream-700 hover:border-sage-400 hover:text-sage-600 dark:hover:text-sage-400 transition-colors cursor-default">
                {tech}
              </span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Scroll reveal
  const observerOptions = {
    threshold: 0.15,
    rootMargin: '0px 0px -50px 0px',
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');

        // Animate skill bars when visible
        if (entry.target.classList.contains('reveal')) {
          const skillBars = entry.target.querySelectorAll('.skill-bar');
          skillBars.forEach((bar, index) => {
            setTimeout(() => {
              bar.style.width = bar.style.getPropertyValue('--target-width');
              bar.style.transition = 'width 1.2s cubic-bezier(0.4, 0, 0.2, 1)';
            }, index * 150 + 300);
          });
        }

        observer.unobserve(entry.target);
      }
    });
  }, observerOptions);

  document.querySelectorAll('#tentang .reveal').forEach((el) => {
    observer.observe(el);
  });
</script>
